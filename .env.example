# ─── Clinic Cards API ─────────────────────────────────────────────────────────
# Get the key: Settings → Other → Clinic Settings → API key (clinic owner only).
# Leave empty to run in DEMO mode with built-in mock patients (no network calls).
CLINIC_CARDS_API_KEY=
CLINIC_CARDS_BASE_URL=https://cliniccards.com/api

# Comma-separated Clinic Cards *status names* that mean "closed / archived".
# Patients that have ANY of these statuses are hidden from the board.
# Matching is case-insensitive. Edit to match your clinic's status names.
CLINIC_CARDS_CLOSED_STATUSES=Выполненный,Отказался

# How far back to look for treatment plans when resolving the "Услуга" field.
CLINIC_CARDS_PLANS_SINCE=2015-01-01

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=8787
# Seconds to cache a Clinic Cards pull before hitting the API again (manual
# refresh always forces a fresh pull). Keeps us well under 60 req/min.
CC_CACHE_TTL_SECONDS=60
# Path to the SQLite file that stores our own board positions.
DB_PATH=./data/board.db

# ─── Board rules ──────────────────────────────────────────────────────────────
# Show a patient for WINDOW_DAYS after заявка creation; each stage advance
# extends the window by another WINDOW_DAYS from the advance date.
WINDOW_DAYS=30
# No stage advance for STUCK_DAYS → patient shows in «Потребують уваги».
STUCK_DAYS=3
# «Гарячі»: upcoming visit within HOT_VISIT_DAYS.
HOT_VISIT_DAYS=1
# Conversion stats window (days).
CONVERSION_WINDOW_DAYS=30
# Диапазон визитов для поля «Коментар» (комментарий визита из CC).
VISITS_BACK_DAYS=60
VISITS_FWD_DAYS=120

# ─── База данных (libSQL / Turso) ─────────────────────────────────────────────
# Локально можно не задавать — используется файл ./data/board.db.
# Для Vercel/прода: создайте БД в Turso (https://turso.tech) и вставьте:
# TURSO_DATABASE_URL=libsql://<your-db>.turso.io
# TURSO_AUTH_TOKEN=<token>
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=
