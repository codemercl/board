# ─── Обязательное ─────────────────────────────────────────────────────────────

# Ключ Clinic Cards (Settings → Other → Clinic Settings → API key).
# Пусто → демо-режим на мок-данных (без обращений к сети).
CLINIC_CARDS_API_KEY=

# Supabase / Postgres — pooled connection string, например:
# postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres
# Пусто → in-memory (локально работает без БД, позиции не сохраняются).
DATABASE_URL=

# ─── Настройка воронки под клинику ────────────────────────────────────────────

# Статусы Clinic Cards, которые считаются «закрыт/архив» (скрыть с борда).
CLINIC_CARDS_CLOSED_STATUSES=Выполненный,Отказался

# ─── Необязательные override (у всех есть разумные значения по умолчанию) ──────
# CLINIC_CARDS_BASE_URL=https://cliniccards.com/api
# Ссылка на профиль пациента в веб-приложении CC ({id} = patient_id).
# По умолчанию — тот же хост, что у BASE_URL, без /api: .../patients/{id}
# CLINIC_CARDS_PATIENT_URL=https://cliniccards.com/patients/{id}
# CLINIC_CARDS_PLANS_SINCE=2015-01-01
# CC_CACHE_TTL_SECONDS=180      # TTL кэша выгрузки CC (лимит API 60/мин)
# WINDOW_DAYS=30                # окно показа пациента от даты заявки
# STUCK_DAYS=3                  # без движения N дней → «Потребують уваги»
# HOT_VISIT_DAYS=1             # «Гарячі»: визит в пределах N дней
# CONVERSION_WINDOW_DAYS=30    # окно расчёта конверсии
# VISITS_BACK_DAYS=60          # диапазон визитов для «Коментар»
# VISITS_FWD_DAYS=120
# PORT=8787                    # для одиночного Node-хоста
